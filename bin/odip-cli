#!/bin/bash

# odip-cli - Command-line interface launcher for ODIP
#
# Requires ODIP_REPO to be set in the environment.
#
# Usage:
#   odip-cli [--user <email>] <command> [args...]
#
# If --user is not provided, defaults to the current OS user ($USER) — which the
# server will reject (401) unless it is a whitelisted email in users.yaml.
# Role is no longer passed: the server resolves it from users.yaml.
#
# Examples:
#   odip-cli stakeholder list
#   odip-cli --user jack@eurocontrol.int requirement list
#   odip-cli document tree

set -e

if [[ -z "$ODIP_REPO" ]]; then
    echo "Error: ODIP_REPO is not set. Add to your .bashrc:"
    echo "  export ODIP_REPO=~/works/github/odp"
    exit 1
fi

CLI_ENTRY="$ODIP_REPO/workspace/cli/src/index.js"

if [[ ! -f "$CLI_ENTRY" ]]; then
    echo "Error: CLI entry point not found: $CLI_ENTRY"
    exit 1
fi

# Inject --user $USER as a fallback if the caller did not supply --user, then
# pass everything through to node. Role is server-derived — no --role.

ARGS=("$@")
HAS_USER=false

for arg in "${ARGS[@]}"; do
    [[ "$arg" == "--user" ]] && HAS_USER=true
done

PREFIX=()
$HAS_USER || PREFIX+=("--user" "$USER")

exec node "$CLI_ENTRY" "${PREFIX[@]}" "${ARGS[@]}"
