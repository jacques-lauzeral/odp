#!/bin/bash


# odip-admin - Administration utility for ODIP (Podman/Kubernetes)
#
# Required environment variables:
#   ODIP_REPO                Repository root (source code, bin, Dockerfile)
#   ODIP_HOME                Runtime root (data/, backups/, logs/)
#   ODIP_DOCKER_REGISTRY     Docker registry (e.g. docker.io or yagi.cfmu.corp.eurocontrol.int:5000)
#   ODIP_NPM_MODE            npm install mode: podman (default) or host
#   ODIP_GEM_MODE            gem install mode: podman (default, online) or host (local ~/.gemrc proxy)

set -e

for var in ODIP_REPO ODIP_HOME ODIP_DOCKER_REGISTRY; do
    if [[ -z "${!var}" ]]; then
        echo "Error: $var is not set." >&2
        exit 1
    fi
done

YAML_FILE="${ODIP_REPO}/odip-deployment.yaml"
SERVER_URL="http://localhost:8080"

# --- Top-level help ---

usage() {
    cat << 'EOF'
Usage: odip-admin <command> [options]

Commands:
  install   One-time installation: download UI bundle (--proxy for EC), npm install, build web client
  start     Start the ODIP pod
  stop      Stop the ODIP pod
  restart   Stop and restart the ODIP pod
  logs      Stream server logs
  dump      Dump Neo4j database (with server standby)
  load      Load Neo4j database (with server standby)
  reset     Reset Neo4j database (with server standby)
  standby   Signal server to enter standby mode
  resume    Signal server to resume normal operation
  dumps     List available backup slots

Run 'odip-admin <command> -h' for command-specific options.
EOF
}

# --- Helpers ---

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"
}

# List all publication works directories
list_works_dirs() {
    echo "${ODIP_HOME}/publication/works"
    echo "${ODIP_HOME}/publication/works-intro"
    local shared_content="${ODIP_REPO}/publication/shared/content"
    if [[ -d "$shared_content" ]]; then
        for d in "$shared_content"/*/; do
            local drg_slug
            drg_slug=$(basename "$d")
            [[ "$drg_slug" == "intro" ]] && continue
            echo "${ODIP_HOME}/publication/works-${drg_slug}"
        done
    fi
}

ensure_runtime_dirs() {
    mkdir -p "${ODIP_HOME}/data"
    mkdir -p "${ODIP_HOME}/backups/auto"
    mkdir -p "${ODIP_HOME}/backups/adhoc"
    mkdir -p "${ODIP_HOME}/backups/reset"
    mkdir -p "${ODIP_HOME}/logs"
    # Create all publication works dirs with open permissions (rootless Podman + NFS)
    while IFS= read -r works_dir; do
        mkdir -p "$works_dir"
        chmod 777 "$works_dir"
    done < <(list_works_dirs)
}

extract_data_dir() {
    local data_dir="$1"
    if [[ -z "$data_dir" ]]; then
        data_dir="${ODIP_HOME}/data"
        log "Using Neo4j data directory: $data_dir" >&2
    fi
    [[ ! -d "$data_dir" ]] && { echo "Error: Neo4j data directory does not exist: $data_dir" >&2; exit 1; }
    echo "$data_dir"
}

extract_neo4j_image() {
    local image="$1"
    if [[ -z "$image" ]]; then
        image=$(awk '/- name: neo4j/{found=1} found && /image:/{print $2; exit}' "$YAML_FILE" | envsubst)
        if [[ -z "$image" ]]; then
            image="${ODIP_DOCKER_REGISTRY}/neo4j:5.15"
            log "Warning: Could not extract Neo4j image, using fallback: $image" >&2
        else
            log "Detected Neo4j image: $image" >&2
        fi
    fi
    echo "$image"
}

signal_standby() {
    log "Signalling server to enter standby"
    curl -sf -X POST "${SERVER_URL}/admin/standby" || { echo "Error: Failed to signal standby" >&2; exit 1; }
    log "Server in standby"
}

signal_resume() {
    log "Signalling server to resume"
    curl -sf -X POST "${SERVER_URL}/admin/resume" || { echo "Error: Failed to signal resume" >&2; exit 1; }
    log "Server resumed"
}

neo4j_stop() {
    log "Stopping Neo4j container"
    podman stop odp-pod-neo4j
}

neo4j_start() {
    log "Starting Neo4j container"
    podman start odp-pod-neo4j
    log "Waiting for Neo4j to be ready..."
    sleep 10
}

install_host_dependencies() {
    log "Installing host dependencies (server, web-client, cli)"
    for workspace in server web-client cli; do
        log "npm install: workspace/$workspace"
        (cd "${ODIP_REPO}/workspace/$workspace" && npm install)
    done
}

build_web_client() {
    log "Rebuilding web client image (ODIP_NPM_MODE=${ODIP_NPM_MODE:-podman})"
    local npm_arg="true"
    [[ "${ODIP_NPM_MODE:-podman}" == "host" ]] && npm_arg="false"
    podman build --no-cache \
        -f "${ODIP_REPO}/Dockerfile.web-client" \
        --build-arg NPM_INSTALL="$npm_arg" \
        -t odp-web-client:latest \
        "$ODIP_REPO"
}

build_odp_server() {
    local gem_mode="${ODIP_GEM_MODE:-podman}"
    log "Rebuilding server image (ODIP_GEM_MODE=${gem_mode})"
    local extra_args=""
    if [[ "$gem_mode" == "host" ]]; then
        # Write proxy URL to a temp file and pass it as a build secret
        local gem_proxy_file
        gem_proxy_file=$(mktemp)
        # Extract http-proxy or https-proxy value from ~/.gemrc
        local proxy_url
        proxy_url=$(grep -E '^\s*https?-proxy:' "$HOME/.gemrc" 2>/dev/null | head -1 | sed 's/.*proxy:[[:space:]]*//')
        [[ -z "$proxy_url" ]] && { echo "Error: no http-proxy or https-proxy found in ~/.gemrc" >&2; rm -f "$gem_proxy_file"; exit 1; }
        echo -n "$proxy_url" > "$gem_proxy_file"
        extra_args="--secret id=gem_proxy,src=$gem_proxy_file"
        extra_args="$extra_args --build-arg http_proxy=$proxy_url"
        extra_args="$extra_args --build-arg https_proxy=$proxy_url"
    fi
    podman build -f "${ODIP_REPO}/Dockerfile.odp-server" \
        $extra_args \
        -t "${ODIP_DOCKER_REGISTRY}/odp-server:latest" \
        "$ODIP_REPO"
    [[ -n "${gem_proxy_file:-}" ]] && rm -f "$gem_proxy_file"
}

# --- Commands ---

EC_PROXY_HOST="pac.eurocontrol.int:9512"
ANTORA_BUNDLE_URL="https://gitlab.com/antora/antora-ui-default/-/jobs/artifacts/HEAD/raw/build/ui-bundle.zip?job=bundle-stable"

cmd_install() {
    local use_proxy=false
    while [[ $# -gt 0 ]]; do
        case $1 in
            --proxy) use_proxy=true; shift ;;
            -h|--help)
                cat << 'EOF'
Usage: odip-admin install [options]

  One-time installation setup:
    - Download Antora UI bundle (requires internet or --proxy)
    - Install npm dependencies for all workspaces
    - Bootstrap and install npm dependencies for all publication works dirs (works/, works-intro/, works-{drg}/)
    - Build server image (gem install mode controlled by ODIP_GEM_MODE)
    - Build web client image

Options:
      --proxy         Use EC corporate proxy (prompts for credentials)
  -h, --help          Show this help

Gem install modes (ODIP_GEM_MODE):
  podman   gem install from rubygems.org during image build (default — personal env)
  host     gem install via proxy URL extracted from ~/.gemrc http-proxy or https-proxy (EC env)

Notes:
  On restricted networks (e.g. EC), direct download of the Antora UI bundle
  will fail. Use --proxy or transfer the bundle manually:

    scp ui-bundle.zip user@host:$ODIP_REPO/publication/shared/config/

  Once the bundle is present in the static directory, re-run install
  (the download step will be skipped automatically).
EOF
                exit 0 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done

    ensure_runtime_dirs

    # Download Antora UI bundle if not already present
    local bundle_src="${ODIP_REPO}/publication/shared/config/ui-bundle.zip"
    if [[ ! -f "$bundle_src" ]]; then
        log "Downloading Antora UI bundle..."
        local curl_opts="-sSL --connect-timeout 5 --max-time 30"
        if [[ "$use_proxy" == true ]]; then
            read -r -p "Proxy username: " proxy_user
            read -r -s -p "Proxy password: " proxy_pass
            echo
            # URL-encode special characters in password
            proxy_pass="${proxy_pass//@/%40}"
            curl_opts="$curl_opts --proxy http://${proxy_user}:${proxy_pass}@${EC_PROXY_HOST}"
            log "Using EC proxy: ${EC_PROXY_HOST}"
        fi
        if curl $curl_opts -o "$bundle_src" "$ANTORA_BUNDLE_URL"; then
            log "Antora UI bundle downloaded"
        else
            rm -f "$bundle_src"
            echo "" >&2
            echo "ERROR: Failed to download Antora UI bundle." >&2
            echo "" >&2
            echo "On restricted networks, transfer the bundle manually:" >&2
            echo "  1. Download on a machine with internet access:" >&2
            echo "     curl -L -o ui-bundle.zip \"$ANTORA_BUNDLE_URL\"" >&2
            echo "  2. Transfer to this machine:" >&2
            echo "     scp ui-bundle.zip <user>@<host>:${ODIP_REPO}/publication/web-site/static/" >&2
            echo "  3. Re-run: odip-admin install" >&2
            echo "" >&2
            exit 1
        fi
    else
        log "Antora UI bundle already present — skipping download"
    fi

    # Bootstrap and install dependencies for all publication works dirs
    local pub_repo="${ODIP_REPO}/publication"
    local website_config="${pub_repo}/website/config"
    local website_content="${pub_repo}/website/content"
    local document_config="${pub_repo}/document/config"
    local shared_config="${pub_repo}/shared/config"
    local shared_content="${pub_repo}/shared/content"

    # Helper: bootstrap a works dir from config source dirs only (content mapping handled at publish time)
    bootstrap_works_dir() {
        local works_dir="$1"; shift
        log "Bootstrapping: $works_dir"
        for src in "$@"; do
            [[ -d "$src" ]] && cp -r "${src}/." "$works_dir/"
        done
    }

    # Helper: npm install in a works dir (idempotent)
    install_works_deps() {
        local works_dir="$1"
        local label="$2"
        if [[ ! -d "${works_dir}/node_modules" ]]; then
            log "npm install: $label"
            (cd "$works_dir" && npm install)
        else
            log "npm install: $label — already installed"
        fi
    }

    # Main works dir: shared config + website config (website config overrides shared)
    bootstrap_works_dir "${ODIP_HOME}/publication/works"         "$shared_config" "$website_config"
    install_works_deps "${ODIP_HOME}/publication/works" "works (main)"

    # Intro works dir: shared config + document config
    bootstrap_works_dir "${ODIP_HOME}/publication/works-intro"         "$shared_config" "$document_config"
    install_works_deps "${ODIP_HOME}/publication/works-intro" "works-intro"

    # Per-DrG works dirs: shared config + document config
    if [[ -d "$shared_content" ]]; then
        for d in "$shared_content"/*/; do
            local drg_slug
            drg_slug=$(basename "$d")
            [[ "$drg_slug" == "intro" ]] && continue
            local domain_works="${ODIP_HOME}/publication/works-${drg_slug}"
            bootstrap_works_dir "$domain_works"                 "$shared_config" "$document_config"
            install_works_deps "$domain_works" "works-${drg_slug}"
        done
    fi

    install_host_dependencies
    build_odp_server
    build_web_client

    log "Installation complete"
}

cmd_start() {
    local rebuild="" install=false
    while [[ $# -gt 0 ]]; do
        case $1 in
            --rebuild=server|--rebuild=web-client|--rebuild=all) rebuild="${1#--rebuild=}"; shift ;;
            --install)  install=true; shift ;;
            -h|--help)
                cat << 'EOF'
Usage: odip-admin start [options]

  Start the ODIP pod.

Options:
      --install               Run npm install for all workspaces (host mode only)
      --rebuild=server        Rebuild server image before starting
      --rebuild=web-client    Rebuild web client image before starting
      --rebuild=all           Rebuild both images before starting
  -h, --help                  Show this help

  Server image gem install mode is controlled by ODIP_GEM_MODE (podman/host).
EOF
                exit 0 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    ensure_runtime_dirs
    [[ "$install" == true ]] && install_host_dependencies
    [[ "$rebuild" == "server" || "$rebuild" == "all" ]] && build_odp_server
    [[ "$rebuild" == "web-client" || "$rebuild" == "all" ]] && build_web_client
    log "Starting ODIP pod"
    envsubst < "$YAML_FILE" | podman play kube -
    log "ODIP pod started"
}

cmd_stop() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            -h|--help)
                cat << 'EOF'
Usage: odip-admin stop

  Stop the ODIP pod.
EOF
                exit 0 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    log "Stopping ODIP pod"
    envsubst < "$YAML_FILE" | podman play kube --down -
    log "ODIP pod stopped"
}

cmd_restart() {
    local rebuild="" install=false
    while [[ $# -gt 0 ]]; do
        case $1 in
            --rebuild=server|--rebuild=web-client|--rebuild=all) rebuild="${1#--rebuild=}"; shift ;;
            --install)  install=true; shift ;;
            -h|--help)
                cat << 'EOF'
Usage: odip-admin restart [options]

  Stop and restart the ODIP pod.

Options:
      --install               Run npm install for all workspaces (host mode only)
      --rebuild=server        Rebuild server image before restarting
      --rebuild=web-client    Rebuild web client image before restarting
      --rebuild=all           Rebuild both images before restarting
  -h, --help                  Show this help

  Server image gem install mode is controlled by ODIP_GEM_MODE (podman/host).
EOF
                exit 0 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    log "Stopping ODIP pod"
    envsubst < "$YAML_FILE" | podman play kube --down -
    ensure_runtime_dirs
    [[ "$install" == true ]] && install_host_dependencies
    [[ "$rebuild" == "server" || "$rebuild" == "all" ]] && build_odp_server
    [[ "$rebuild" == "web-client" || "$rebuild" == "all" ]] && build_web_client
    log "Starting ODIP pod"
    envsubst < "$YAML_FILE" | podman play kube -
    log "ODIP pod restarted"
}

cmd_logs() {
    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        cat << 'EOF'
Usage: odip-admin logs [podman-logs-options]

  Stream server logs. All options are passed through to podman logs.

Examples:
  odip-admin logs
  odip-admin logs -f
  odip-admin logs --tail 100
  odip-admin logs --since 1h
EOF
        exit 0
    fi
    podman logs "$@" odp-pod-odp-server
}

cmd_dump() {
    local backup_dir="" data_dir="" neo4j_image=""
    while [[ $# -gt 0 ]]; do
        case $1 in
            -b|--backup-dir) backup_dir="$2"; shift 2 ;;
            -d|--data-dir)   data_dir="$2"; shift 2 ;;
            -i|--image)      neo4j_image="$2"; shift 2 ;;
            -h|--help)
                cat << 'EOF'
Usage: odip-admin dump [options]

  Place server in standby, stop Neo4j, dump database, restart Neo4j, resume server.

Options:
  -b, --backup-dir <path>   Backup directory (default: $ODIP_HOME/backups/<timestamp>)
  -d, --data-dir <path>     Neo4j data directory (default: $ODIP_HOME/data)
  -i, --image <name>        Neo4j image (default: auto-detect from YAML)
  -h, --help                Show this help
EOF
                exit 0 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    data_dir=$(extract_data_dir "$data_dir")
    neo4j_image=$(extract_neo4j_image "$neo4j_image")
    [[ -z "$backup_dir" ]] && backup_dir="${ODIP_HOME}/backups/adhoc/$(date +%Y%m%d-%H%M)"
    backup_dir=$(realpath -m "$backup_dir")
    log "Creating backup directory: $backup_dir"
    mkdir -p "$backup_dir"
    chmod 777 "$backup_dir"
    signal_standby
    neo4j_stop
    log "Dumping database to: $backup_dir"
    podman run --rm \
        --entrypoint neo4j-admin \
        -v "$data_dir":/data \
        -v "$backup_dir":/backup \
        "$neo4j_image" \
        database dump neo4j --to-path=/backup
    neo4j_start
    signal_resume
    log "Backup complete: $backup_dir/neo4j.dump"
}

cmd_load() {
    local backup_dir="" data_dir="" neo4j_image=""
    while [[ $# -gt 0 ]]; do
        case $1 in
            -b|--backup-dir) backup_dir="$2"; shift 2 ;;
            -d|--data-dir)   data_dir="$2"; shift 2 ;;
            -i|--image)      neo4j_image="$2"; shift 2 ;;
            -h|--help)
                cat << 'EOF'
Usage: odip-admin load [options]

  Place server in standby, stop Neo4j, load database from backup, restart Neo4j, resume server.

Options:
  -b, --backup-dir <path>   Backup directory containing neo4j.dump (required)
  -d, --data-dir <path>     Neo4j data directory (default: $ODIP_HOME/data)
  -i, --image <name>        Neo4j image (default: auto-detect from YAML)
  -h, --help                Show this help
EOF
                exit 0 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    [[ -z "$backup_dir" ]] && { echo "Error: --backup-dir is required" >&2; exit 1; }
    backup_dir=$(realpath -m "$backup_dir")
    [[ ! -f "$backup_dir/neo4j.dump" ]] && { echo "Error: Backup file not found: $backup_dir/neo4j.dump" >&2; exit 1; }
    data_dir=$(extract_data_dir "$data_dir")
    neo4j_image=$(extract_neo4j_image "$neo4j_image")
    signal_standby
    neo4j_stop
    log "Loading database from: $backup_dir"
    podman run --rm \
        --entrypoint neo4j-admin \
        -v "$data_dir":/data \
        -v "$backup_dir":/backup \
        "$neo4j_image" \
        database load neo4j --from-path=/backup --overwrite-destination=true
    neo4j_start
    signal_resume
    log "Restore complete"
}

cmd_reset() {
    local backup_dir="" data_dir="" neo4j_image=""
    while [[ $# -gt 0 ]]; do
        case $1 in
            -b|--backup-dir) backup_dir="$2"; shift 2 ;;
            -d|--data-dir)   data_dir="$2"; shift 2 ;;
            -i|--image)      neo4j_image="$2"; shift 2 ;;
            -h|--help)
                cat << 'EOF'
Usage: odip-admin reset [options]

  Place server in standby, stop Neo4j, dump database to backup directory,
  delete data directory contents (empty database on restart), restart Neo4j,
  resume server. Requires YES confirmation.

Options:
  -b, --backup-dir <path>  Backup directory for the pre-reset dump
                           (default: $ODIP_HOME/backups/reset-<timestamp>)
  -d, --data-dir <path>    Neo4j data directory (default: $ODIP_HOME/data)
  -i, --image <name>       Neo4j image (default: auto-detect from YAML)
  -h, --help               Show this help
EOF
                exit 0 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    data_dir=$(extract_data_dir "$data_dir")
    neo4j_image=$(extract_neo4j_image "$neo4j_image")
    [[ -z "$backup_dir" ]] && backup_dir="${ODIP_HOME}/backups/reset/$(date +%Y%m%d-%H%M)"
    backup_dir=$(realpath -m "$backup_dir")
    echo "==> This will reset the Neo4j database."
    echo "    A dump of the current data will be saved to:"
    echo "      $backup_dir/neo4j.dump"
    echo "    Data directory:"
    echo "      $data_dir"
    echo ""
    read -r -p "Type YES to confirm: " CONFIRM
    [[ "$CONFIRM" != "YES" ]] && { echo "Aborted."; exit 0; }
    log "Creating backup directory: $backup_dir"
    mkdir -p "$backup_dir"
    chmod 777 "$backup_dir"
    signal_standby
    neo4j_stop
    log "Dumping database to: $backup_dir"
    podman run --rm \
        --entrypoint neo4j-admin \
        -v "$data_dir":/data \
        -v "$backup_dir":/backup \
        "$neo4j_image" \
        database dump neo4j --to-path=/backup
    log "Deleting data directory contents"
    podman run --rm --user root \
        -v "$data_dir":/data \
        "$neo4j_image" \
        bash -c "find /data -maxdepth 1 -mindepth 1 -exec rm -rf {} +"
    neo4j_start
    signal_resume
    log "Reset complete. Pre-reset dump preserved at: $backup_dir/neo4j.dump"
}

cmd_standby() {
    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        cat << 'EOF'
Usage: odip-admin standby

  Signal the server to enter standby mode.
  The server rejects all non-admin requests with 503 until resumed.
EOF
        exit 0
    fi
    signal_standby
}

cmd_resume() {
    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        cat << 'EOF'
Usage: odip-admin resume

  Signal the server to resume normal operation after standby.
EOF
        exit 0
    fi
    signal_resume
}

format_age() {
    local age_sec="$1"
    if (( age_sec < 3600 )); then
        echo "$((age_sec / 60))m ago"
    elif (( age_sec < 86400 )); then
        echo "$((age_sec / 3600))h ago"
    else
        echo "$((age_sec / 86400))d ago"
    fi
}

print_dump_row() {
    printf "%-20s %-10s %s\n" "$1" "$2" "$3"
}

print_section_header() {
    echo ""
    print_dump_row "$1" "SIZE" "AGE"
    print_dump_row "--------------------" "----------" "-------"
}

scan_dump_dir() {
    local dir="$1"
    local now="$2"
    local found=false
    for subdir in "$dir"/*/; do
        [[ -d "$subdir" ]] || continue
        local dump="$subdir/neo4j.dump"
        [[ -f "$dump" ]] || continue
        local size mtime age_sec
        size=$(du -sh "$dump" | cut -f1)
        mtime=$(stat -c %Y "$dump")
        age_sec=$(( now - mtime ))
        print_dump_row "$(basename "$subdir")" "$size" "$(format_age $age_sec)"
        found=true
    done
    [[ "$found" == false ]] && print_dump_row "(none)" "-" "" || true
}

cmd_dumps() {
    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        echo "Usage: odip-admin dumps"
        echo ""
        echo "  List available backup dumps with file size and age."
        echo "  Organised in three sections: auto (scheduled), adhoc (manual), reset (pre-reset)."
        exit 0
    fi

    local base="${ODIP_HOME}/backups"
    local now; now=$(date +%s)

    print_section_header "AUTO"
    for slot in daily weekly monthly; do
        local dump="$base/auto/$slot/neo4j.dump"
        if [[ -f "$dump" ]]; then
            local size mtime age_sec
            size=$(du -sh "$dump" | cut -f1)
            mtime=$(stat -c %Y "$dump")
            age_sec=$(( now - mtime ))
            print_dump_row "$slot" "$size" "$(format_age $age_sec)"
        else
            print_dump_row "$slot" "-" "no dump"
        fi
    done

    print_section_header "ADHOC"
    scan_dump_dir "$base/adhoc" "$now"

    print_section_header "RESET"
    scan_dump_dir "$base/reset" "$now"
}

# --- Dispatch ---

if [[ $# -eq 0 ]]; then
    usage
    exit 0
fi

COMMAND="$1"; shift

case "$COMMAND" in
    install)   cmd_install "$@" ;;
    start)     cmd_start "$@" ;;
    stop)      cmd_stop "$@" ;;
    restart)   cmd_restart "$@" ;;
    logs)      cmd_logs "$@" ;;
    dump)      cmd_dump "$@" ;;
    load)      cmd_load "$@" ;;
    reset)     cmd_reset "$@" ;;
    standby)   cmd_standby "$@" ;;
    resume)    cmd_resume "$@" ;;
    dumps)     cmd_dumps "$@" ;;
    -h|--help) usage ;;
    *) echo "Unknown command: $COMMAND"; usage; exit 1 ;;
esac