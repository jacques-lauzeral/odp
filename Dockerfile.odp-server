FROM node:20

# Install Ruby and asciidoctor-pdf for PDF publication
RUN apt-get update && apt-get install -y --no-install-recommends \
        ruby \
        ruby-dev \
        build-essential \
        libxml2-dev \
        libxslt-dev \
    && gem install asciidoctor-pdf rouge \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app/workspace/server
CMD ["npm", "run", "dev"]