= ON {{title}}

[.metadata]
--
*_Code:_* {{code}} +
*_Domain:_* {{drg}} +
{{#refinesParents}}
*_Refines:_* xref:{{{parentXref}}}[{{parentTitle}}]
{{/refinesParents}}
--

{{#statement}}
*_Statement:_* +
{{{statement}}}
{{/statement}}

{{#rationale}}
*_Rationale:_* +
{{{rationale}}}
{{/rationale}}

{{#flows}}
*_Flow Descriptions and Examples:_* +
{{{flows}}}
{{/flows}}

{{#strategicDocuments}}
*_Strategic Documents:_* +
--
{{#items}}
* {{#url}}link:{{{url}}}[{{title}} {{version}}]{{/url}}{{^url}}{{title}} {{version}}{{/url}} {{#note}}({{{note}}}){{/note}}
{{/items}}
--
{{/strategicDocuments}}

{{#refinedBy}}
*_Refined By_* +
--
{{#items}}
* xref:{{{xref}}}[{{type}} {{title}}]
{{/items}}
--
{{/refinedBy}}

{{#implementedBy}}
*_Implemented By:_* +
--
{{#items}}
* xref:{{{xref}}}[OR {{title}}]
{{/items}}
--
{{/implementedBy}}